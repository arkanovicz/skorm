database example {

  schema bookshelf {

    table dude {
      !name varchar(100)
    }

    table author {
      name varchar(100)
    }

    table book {
      title varchar(100)
      genre enum('fiction', 'novel', 'essay', 'poetry')
      donor --> dude?
    }

    table borrowing {
      borrowing_date date
      restitution_date date?
    }

    book --> author
    borrowing -> book
    borrowing -> dude

  }

}
